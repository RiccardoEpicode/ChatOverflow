@{
    ViewData["Title"] = "ChatRoom Page";
}

<div class="main">
    <div>
        <h1>Supercharge Your Problem-Solving Potential</h1>
        <div class="animation-container">
            <img src="~/Images/rocket.png" alt="Rocket" class="animated-element">
        </div>
        <p>
            With our chat service, we bring you the ultimate fusion of StackOverflow and real-time chat. 
            Say goodbye to endless waiting and hello to instant, accurate answers from the community.
        </p>
        <p>
            Take your projects to new heights with swift progress and unparalleled collaboration.
        </p>
        <h2>Features:</h2>
        <div style="text-align: center;">
            <ul class="feature-list">
                <li class="feature-item">Instant and Accurate Answers from the Community</li>
                <li class="feature-item">Real-Time Chat for Swift Progress</li>
                <li class="feature-item">Unparalleled Collaboration for Projects</li>
                <li class="feature-item">Easy Access to Expertise and Knowledge</li>
                <li class="feature-item">Vibrant Community of Developers</li>
                <li class="feature-item">Efficient Problem-Solving Environment</li>
            </ul>
        </div>
        <div class="gif-container">
            <img src="~/Images/chat.gif" alt="Chat Gif" class="chat-gif">
        </div>
        <p class="highlight">
            Join our chat service today and experience the power of collaboration and knowledge-sharing!
        </p>

        <div class="button-section">
            <button type="button" class="btn btnCustom">Login</button>
        </div>
    </div>

</div>